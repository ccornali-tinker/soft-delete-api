{
  "name": "soft-delete-items-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "30-minute interview exercise: soft delete + restore (TypeScript + PostgreSQL)",
  "scripts": {
    "start": "tsx src/index.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "npm run db:migrate && npm run db:seed"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
